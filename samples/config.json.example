{
    "Settings": {
        "logLevel": "info",
        "bootstrap": {
            "caUrl": "https://ca.corp.example.com:9000"
        },
        "trust": {
            "installRoots": true,
            "refreshInterval": "24h"
        }
    },
    "Provisioners": [
        {
            "name": "workstation-identity",
            "enabled": true,
            "installToStore": true,
            "store": "localmachine",
            "caProvisioner": "device-identity",
            "friendlyName": "auto",
            "subject": {
                "commonName": "auto",
                "dnsNames": ["auto"],
                "ipAddresses": ["auto"]
            },
            "auth": {
                "type": "provisioner-password",
                "password": "CHANGE-ME-provisioner-secret"
            }
        },
        {
            "name": "web-api-tls",
            "enabled": true,
            "installToStore": false,
            "store": "currentuser",
            "caProvisioner": "svc-web",
            "friendlyName": "My Custom TLS Cert",
            "subject": {
                "commonName": "auto",
                "dnsNames": ["auto"],
                "ipAddresses": ["auto"]
            },
            "key": {
                "algorithm": "EC",
                "curve": "P384"
            },
            "auth": {
                "type": "provisioner-password",
                "password": "CHANGE-ME-provisioner-secret"
            }
        }
    ]
}

